# Postgres connection string used by the ETL scripts and the backend API.
# Local dev (docker/local postgres):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fifawc

# Supabase (production): copy the "Connection string" (URI, transaction pooler)
# from Project Settings -> Database in the Supabase dashboard.
# DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

PORT=4000
